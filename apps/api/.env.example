# ─── Neon PostgreSQL ─────────────────────────────────────────────────────────
# Runtime (pg driver adapter) — Neon POOLED endpoint. Host contains "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
# Prisma migrations / introspection ONLY — Neon DIRECT (unpooled) endpoint. Never the pooler.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Vercel frontend origin allowed by CORS.
CORS_ORIGIN="http://localhost:3000"
WEB_APP_URL="http://localhost:3000"
API_BASE_URL="http://localhost:4000"

# ─── Auth (JWT sessions) ─────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=""
REFRESH_TOKEN_SECRET=""

# ─── AI (Gemini) ─────────────────────────────────────────────────────────────
# Optional: a missing key degrades AI to "summary unavailable" and never blocks boot.
GEMINI_API_KEY=""
# Flash-class tuning — sane defaults applied when unset (see src/config/env.ts).
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_TIMEOUT_MS=8000

# ─── SMTP (invites, resets, reminders, alerts) ───────────────────────────────
# Optional: unset degrades the email queue to log-only (no PII logged) and never blocks boot.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Standup Tracker <no-reply@example.com>"
SMTP_SECURE=false

# ─── Scheduler (member reminders, lead blocker alerts) ────────────────────────
SCHEDULER_INTERVAL_MS=300000
REMINDER_LOCAL_HOUR=9
